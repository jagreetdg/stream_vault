# API Server
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streamvault
REDIS_URL=redis://localhost:6379
PORT=8080

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000   # MinIO for local dev
S3_BUCKET=streamvault
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CDN / Public URL for HLS delivery
# Local: point to MinIO public URL
# Prod: CloudFront or Cloudflare distribution URL
CDN_BASE_URL=http://localhost:9000/streamvault

# Worker
WORKER_CONCURRENCY=2              # Parallel transcode jobs per worker node
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg # Changed from /usr/bin/ffmpeg for Mac OS
